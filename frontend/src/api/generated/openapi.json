            "type": "integer",
            "title": "Routine Id"
          },
          "position": {
            "type": "integer",
            "title": "Position"
          },
          "action_type": {
            "type": "string",
            "title": "Action Type"
          },
          "config": {
            "additionalProperties": true,
            "type": "object",
            "title": "Config"
