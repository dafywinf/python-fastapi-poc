# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sequences_db

# ─── JWT / Auth ───────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-long-random-secret

# Generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=$2b$12$...

# Enables POST /auth/token (password grant).
# Set true for local development (required to run E2E tests via `just ci`).
# Set false in production — Google OAuth is the intended auth method.
ENABLE_PASSWORD_AUTH=false

# ─── Google OAuth2 ────────────────────────────────────────────────────────────
# Obtain from: Google Cloud Console → APIs & Services → Credentials → OAuth client ID
# See docs/google-oauth-setup.md for the full setup walkthrough.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# URLs used to construct OAuth redirect URIs — leave as-is for local dev
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# ─── Observability (optional) ─────────────────────────────────────────────────
# Uncomment to enable Loki log shipping (requires just platform-up)
# LOKI_URL=http://localhost:3100
